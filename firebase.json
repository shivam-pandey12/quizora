{
  "apphosting": {
    "backendId": "quizora",
    "rootDir": "/",
    "ignore": [
      "node_modules",
      ".git",
      ".next",
      ".env",
      ".env.*",
      "firebase-debug.log",
      "firebase-debug.*.log"
    ]
  },
  "firestore": {
    "database": "(default)",
    "location": "asia-south2",
    "rules": "firestore.rules",
    "indexes": "firestore.indexes.json"
  }
}
