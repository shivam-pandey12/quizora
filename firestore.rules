rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isSelf(uid) {
      return signedIn() && request.auth.uid == uid;
    }

    function userPath(uid) {
      return /databases/$(database)/documents/users/$(uid);
    }

    function adminProfilePath() {
      return userPath(request.auth.uid);
    }

    function isAdmin() {
      return signedIn()
        && exists(adminProfilePath())
        && get(adminProfilePath()).data.role == 'admin';
    }

    function hasCreatorAccess() {
      return isAdmin()
        || (
          signedIn()
          && exists(adminProfilePath())
          && get(adminProfilePath()).data.creatorStatus == 'approved'
        );
    }

    function classPath(classId) {
      return /databases/$(database)/documents/classes/$(classId);
    }

    function classInvitePath(inviteCode) {
      return /databases/$(database)/documents/classInvites/$(inviteCode);
    }

    function classExists(classId) {
      return classId is string && exists(classPath(classId));
    }

    function classExistsAfter(classId) {
      return classId is string && existsAfter(classPath(classId));
    }

    function classMemberDocId(classId, uid) {
      return classId + '_' + uid;
    }

    function classMemberPath(classId, uid) {
      return /databases/$(database)/documents/classMembers/$(classMemberDocId(classId, uid));
    }

    function isClassOwner(classId) {
      return signedIn()
        && classExists(classId)
        && get(classPath(classId)).data.ownerId == request.auth.uid;
    }

    function isClassOwnerAfter(classId) {
      return signedIn()
        && classExistsAfter(classId)
        && getAfter(classPath(classId)).data.ownerId == request.auth.uid;
    }

    function isActiveClass(classId) {
      return classExists(classId)
        && get(classPath(classId)).data.status == 'active';
    }

    function isActiveClassMember(classId) {
      return signedIn()
        && classExists(classId)
        && exists(classMemberPath(classId, request.auth.uid))
        && get(classMemberPath(classId, request.auth.uid)).data.status == 'active';
    }

    function isClassTeacher(classId) {
      return signedIn()
        && classExists(classId)
        && exists(classMemberPath(classId, request.auth.uid))
        && get(classMemberPath(classId, request.auth.uid)).data.status == 'active'
        && (
          get(classMemberPath(classId, request.auth.uid)).data.role == 'teacher'
          || get(classMemberPath(classId, request.auth.uid)).data.role == 'assistant'
        );
    }

    function canManageClass(classId) {
      return isAdmin() || isClassOwner(classId) || isClassTeacher(classId);
    }

    function canManageClassAfter(classId) {
      return isAdmin() || isClassOwnerAfter(classId);
    }

    function quizPath(quizId) {
      return /databases/$(database)/documents/quizzes/$(quizId);
    }

    function quizExists(quizId) {
      return quizId is string && exists(quizPath(quizId));
    }

    function isQuizOwner(quizId) {
      return signedIn()
        && quizExists(quizId)
        && get(quizPath(quizId)).data.ownerId == request.auth.uid;
    }

    function roomPath(roomId) {
      return /databases/$(database)/documents/rooms/$(roomId);
    }

    function roomExists(roomId) {
      return roomId is string && exists(roomPath(roomId));
    }

    function roomExistsAfter(roomId) {
      return roomId is string && existsAfter(roomPath(roomId));
    }

    function roomAcceptsRealPlayer(roomId) {
      return (
          roomExists(roomId)
          && (
            get(roomPath(roomId)).data.status == 'waiting'
            || (
              get(roomPath(roomId)).data.status == 'in-progress'
              && get(roomPath(roomId)).data.settings.allowLateJoin == true
            )
          )
          && (
            get(roomPath(roomId)).data.locked != true
            || get(roomPath(roomId)).data.hostId == request.auth.uid
          )
          && (
            get(roomPath(roomId)).data.allowedMemberOnly != true
            || get(roomPath(roomId)).data.hostId == request.auth.uid
            || isActiveClassMember(get(roomPath(roomId)).data.classId)
          )
          && get(roomPath(roomId)).data.playerCount < get(roomPath(roomId)).data.maxPlayers
        )
        || (
          !roomExists(roomId)
          && roomExistsAfter(roomId)
          && getAfter(roomPath(roomId)).data.hostId == request.auth.uid
          && getAfter(roomPath(roomId)).data.status == 'waiting'
        );
    }

    function roomPlayerDocId(roomId, uid) {
      return roomId + '_' + uid;
    }

    function roomPlayerPath(roomId, uid) {
      return /databases/$(database)/documents/roomPlayers/$(roomPlayerDocId(roomId, uid));
    }

    function isRoomHost(roomId) {
      return signedIn()
        && roomExists(roomId)
        && get(roomPath(roomId)).data.hostId == request.auth.uid;
    }

    function isRoomParticipant(roomId) {
      return signedIn()
        && roomExists(roomId)
        && exists(roomPlayerPath(roomId, request.auth.uid));
    }

    function flashQuizPath(flashQuizId) {
      return /databases/$(database)/documents/flashQuizzes/$(flashQuizId);
    }

    function flashQuizExists(flashQuizId) {
      return flashQuizId is string && exists(flashQuizPath(flashQuizId));
    }

    function flashPlayerDocId(flashQuizId, uid) {
      return flashQuizId + '_' + uid;
    }

    function flashPlayerPath(flashQuizId, uid) {
      return /databases/$(database)/documents/flashPlayers/$(flashPlayerDocId(flashQuizId, uid));
    }

    function isFlashHost(flashQuizId) {
      return signedIn()
        && flashQuizExists(flashQuizId)
        && get(flashQuizPath(flashQuizId)).data.hostId == request.auth.uid;
    }

    function isFlashParticipant(flashQuizId) {
      return signedIn()
        && flashQuizExists(flashQuizId)
        && exists(flashPlayerPath(flashQuizId, request.auth.uid));
    }

    function canReadFlashQuiz(flashQuizId) {
      return signedIn()
        && (
          isAdmin()
          || isFlashHost(flashQuizId)
          || isFlashParticipant(flashQuizId)
          || (
            get(flashQuizPath(flashQuizId)).data.visibility == 'link-only'
            && get(flashQuizPath(flashQuizId)).data.status in ['active', 'running', 'ended', 'expired']
          )
        );
    }

    function canReadFlashScopedData(flashQuizId) {
      return isAdmin() || isFlashHost(flashQuizId) || isFlashParticipant(flashQuizId);
    }

    function isRoomParticipantAfter(roomId) {
      return signedIn()
        && roomExists(roomId)
        && existsAfter(roomPlayerPath(roomId, request.auth.uid));
    }

    function roomIsWaiting(roomId) {
      return roomExists(roomId)
        && get(roomPath(roomId)).data.status == 'waiting';
    }

    function canReadRoomScopedData(roomId) {
      return isAdmin()
        || isRoomHost(roomId)
        || isRoomParticipant(roomId)
        || (
          roomIsWaiting(roomId)
          && (
            get(roomPath(roomId)).data.allowedMemberOnly != true
            || isActiveClassMember(get(roomPath(roomId)).data.classId)
          )
        );
    }

    function publicQuizReadAllowed(data) {
      return data.status == 'published'
        && data.visibility == 'public'
        && (
          !data.keys().hasAny(['publishScope'])
          || data.publishScope == 'global'
        )
        && (
          !data.keys().hasAny(['ownerType'])
          || data.ownerType == 'admin'
          || (
            data.ownerType == 'creator'
            && data.reviewStatus == 'approved'
          )
        );
    }

    function isPublishedPublicQuiz(quizId) {
      return exists(/databases/$(database)/documents/quizzes/$(quizId))
        && publicQuizReadAllowed(get(/databases/$(database)/documents/quizzes/$(quizId)).data);
    }

    function attemptPath(attemptId) {
      return /databases/$(database)/documents/attempts/$(attemptId);
    }

    function attemptBelongsToRequester(attemptId) {
      return signedIn()
        && attemptId is string
        && exists(attemptPath(attemptId))
        && get(attemptPath(attemptId)).data.userId == request.auth.uid;
    }

    function isShortString(value, maxSize) {
      return value is string && value.size() <= maxSize;
    }

    function nullableShortString(value, maxSize) {
      return value == null || isShortString(value, maxSize);
    }

    function nonNegativeNumber(value, maxValue) {
      return value is number && value >= 0 && value <= maxValue;
    }

    function nullableTimestamp(value) {
      return value == null || value is timestamp;
    }

    function boundedList(value, maxSize) {
      return value is list && value.size() <= maxSize;
    }

    function userProfileKeys() {
      return [
        'uid',
        'displayName',
        'email',
        'photoURL',
        'role',
        'xp',
        'level',
        'totalQuizzesPlayed',
        'averageAccuracy',
        'currentStreak',
        'longestStreak',
        'lastPlayedDate',
        'streakUpdatedAt',
        'earnedBadges',
        'lastBadgeUnlocks',
        'categoryIdsPlayed',
        'quickMatchesPlayed',
        'quickMatchesWon',
        'quickMatchBestRank',
        'quickMatchAverageAccuracy',
        'botMatchesPlayed',
        'challengeMatchesPlayed',
        'creatorStatus',
        'teacherProfile',
        'createdClassCount',
        'joinedClassCount',
        'creatorQuizCount',
        'assignmentsCompleted',
        'assignmentAverageAccuracy',
        'bestClassRank',
        'lastCreatorActivityAt',
        'createdAt',
        'updatedAt',
        'lastActiveAt'
      ];
    }

    function userProfileCreateShape(data, uid) {
      return data.keys().hasOnly(userProfileKeys())
        && data.uid == uid
        && isShortString(data.displayName, 80)
        && isShortString(data.email, 180)
        && nullableShortString(data.photoURL, 600)
        && userProfileRoleAllowed(data)
        && nonNegativeNumber(data.xp, 10000000)
        && nonNegativeNumber(data.level, 10000)
        && nonNegativeNumber(data.totalQuizzesPlayed, 100000)
        && nonNegativeNumber(data.averageAccuracy, 100)
        && nonNegativeNumber(data.currentStreak, 10000)
        && nonNegativeNumber(data.longestStreak, 10000)
        && nullableShortString(data.lastPlayedDate, 20)
        && nullableTimestamp(data.streakUpdatedAt)
        && boundedList(data.earnedBadges, 80)
        && boundedList(data.lastBadgeUnlocks, 20)
        && boundedList(data.categoryIdsPlayed, 200)
        && nonNegativeNumber(data.quickMatchesPlayed, 100000)
        && nonNegativeNumber(data.quickMatchesWon, 100000)
        && nonNegativeNumber(data.quickMatchBestRank, 100000)
        && nonNegativeNumber(data.quickMatchAverageAccuracy, 100)
        && nonNegativeNumber(data.botMatchesPlayed, 100000)
        && nonNegativeNumber(data.challengeMatchesPlayed, 100000)
        && creatorStatusAllowed(data.creatorStatus)
        && (
          data.creatorStatus == 'none'
          || data.creatorStatus == 'pending'
          || isAdmin()
        )
        && (data.teacherProfile == null || data.teacherProfile is map)
        && nonNegativeNumber(data.createdClassCount, 10000)
        && nonNegativeNumber(data.joinedClassCount, 10000)
        && nonNegativeNumber(data.creatorQuizCount, 10000)
        && nonNegativeNumber(data.assignmentsCompleted, 100000)
        && nonNegativeNumber(data.assignmentAverageAccuracy, 100)
        && nonNegativeNumber(data.bestClassRank, 100000)
        && nullableTimestamp(data.lastCreatorActivityAt)
        && nullableTimestamp(data.createdAt)
        && nullableTimestamp(data.updatedAt)
        && nullableTimestamp(data.lastActiveAt);
    }

    function optionalNonNegative(data, field, maxValue) {
      return !data.keys().hasAny([field]) || nonNegativeNumber(data[field], maxValue);
    }

    function optionalShortString(data, field, maxSize) {
      return !data.keys().hasAny([field]) || isShortString(data[field], maxSize);
    }

    function optionalNullableShortString(data, field, maxSize) {
      return !data.keys().hasAny([field]) || nullableShortString(data[field], maxSize);
    }

    function optionalNullableTimestamp(data, field) {
      return !data.keys().hasAny([field]) || nullableTimestamp(data[field]);
    }

    function optionalBoundedList(data, field, maxSize) {
      return !data.keys().hasAny([field]) || boundedList(data[field], maxSize);
    }

    function optionalNullableMap(data, field) {
      return !data.keys().hasAny([field]) || data[field] == null || data[field] is map;
    }

    function creatorStatusAllowed(value) {
      return value == 'none'
        || value == 'pending'
        || value == 'approved'
        || value == 'suspended';
    }

    function userProfileRoleAllowed(data) {
      return data.role == 'user';
    }

    function userProfileUpdateShape(data, uid) {
      return data.keys().hasOnly(userProfileKeys())
        && data.uid == uid
        && userProfileRoleAllowed(data)
        && optionalShortString(data, 'displayName', 80)
        && optionalShortString(data, 'email', 180)
        && optionalNullableShortString(data, 'photoURL', 600)
        && optionalNonNegative(data, 'xp', 10000000)
        && optionalNonNegative(data, 'level', 10000)
        && optionalNonNegative(data, 'totalQuizzesPlayed', 100000)
        && optionalNonNegative(data, 'averageAccuracy', 100)
        && optionalNonNegative(data, 'currentStreak', 10000)
        && optionalNonNegative(data, 'longestStreak', 10000)
        && optionalNullableShortString(data, 'lastPlayedDate', 20)
        && optionalNullableTimestamp(data, 'streakUpdatedAt')
        && optionalBoundedList(data, 'earnedBadges', 80)
        && optionalBoundedList(data, 'lastBadgeUnlocks', 20)
        && optionalBoundedList(data, 'categoryIdsPlayed', 200)
        && optionalNonNegative(data, 'quickMatchesPlayed', 100000)
        && optionalNonNegative(data, 'quickMatchesWon', 100000)
        && optionalNonNegative(data, 'quickMatchBestRank', 100000)
        && optionalNonNegative(data, 'quickMatchAverageAccuracy', 100)
        && optionalNonNegative(data, 'botMatchesPlayed', 100000)
        && optionalNonNegative(data, 'challengeMatchesPlayed', 100000)
        && (!data.keys().hasAny(['creatorStatus']) || creatorStatusAllowed(data.creatorStatus))
        && optionalNullableMap(data, 'teacherProfile')
        && optionalNonNegative(data, 'createdClassCount', 10000)
        && optionalNonNegative(data, 'joinedClassCount', 10000)
        && optionalNonNegative(data, 'creatorQuizCount', 10000)
        && optionalNonNegative(data, 'assignmentsCompleted', 100000)
        && optionalNonNegative(data, 'assignmentAverageAccuracy', 100)
        && optionalNonNegative(data, 'bestClassRank', 100000)
        && optionalNullableTimestamp(data, 'lastCreatorActivityAt')
        && optionalNullableTimestamp(data, 'createdAt')
        && optionalNullableTimestamp(data, 'updatedAt')
        && optionalNullableTimestamp(data, 'lastActiveAt');
    }

    function selfProfileUpdateAllowed(uid) {
      return isSelf(uid)
        && request.resource.data.uid == resource.data.uid
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'displayName',
          'photoURL',
          'lastActiveAt',
          'updatedAt'
        ])
        && request.resource.data.role == resource.data.role
        && userProfileUpdateShape(request.resource.data, uid);
    }

    function attemptShape(data) {
      return data.keys().hasAll([
          'userId',
          'mode',
          'quizId',
          'quizTitle',
          'status',
          'score',
          'totalPoints',
          'accuracy',
          'timeTakenSeconds',
          'totalQuestions',
          'answers'
        ])
        && data.userId == request.auth.uid
        && (data.mode == 'solo' || data.mode == 'live-room' || data.mode == 'assignment')
        && data.status == 'completed'
        && isShortString(data.quizId, 160)
        && isShortString(data.quizTitle, 220)
        && nullableShortString(data.roomId, 180)
        && nullableShortString(data.roomCode, 20)
        && nullableShortString(data.classId, 180)
        && nullableShortString(data.className, 180)
        && nullableShortString(data.assignmentId, 180)
        && nullableShortString(data.assignmentTitle, 260)
        && (
          data.mode != 'assignment'
          || (
            isShortString(data.classId, 180)
            && isShortString(data.assignmentId, 180)
            && isActiveClassMember(data.classId)
          )
        )
        && nonNegativeNumber(data.score, 1000000)
        && nonNegativeNumber(data.totalPoints, 1000000)
        && nonNegativeNumber(data.correctCount, 10000)
        && nonNegativeNumber(data.wrongCount, 10000)
        && nonNegativeNumber(data.skippedCount, 10000)
        && nonNegativeNumber(data.totalQuestions, 10000)
        && nonNegativeNumber(data.accuracy, 100)
        && nonNegativeNumber(data.timeTakenSeconds, 86400)
        && nonNegativeNumber(data.xpEarned, 1000000)
        && boundedList(data.answers, 250)
        && boundedList(data.badgeUnlocks, 20)
        && data.leaderboardUpdated == false;
    }

    function leaderboardClientKeys() {
      return [
        'scope',
        'scopeId',
        'userId',
        'userDisplayName',
        'userPhotoURL',
        'quizId',
        'quizSlug',
        'quizTitle',
        'categoryId',
        'categoryName',
        'difficulty',
        'score',
        'totalPoints',
        'accuracy',
        'timeTakenSeconds',
        'correctCount',
        'wrongCount',
        'skippedCount',
        'attemptId',
        'periodType',
        'periodKey',
        'rankScore',
        'aggregateAttempts',
        'hidden',
        'completedAt',
        'createdAt',
        'updatedAt'
      ];
    }

    function leaderboardFieldsAreSane(data) {
      return data.keys().hasOnly(leaderboardClientKeys())
        && data.userId == request.auth.uid
        && (data.scope == 'global' || data.scope == 'quiz' || data.scope == 'category')
        && (data.periodType == 'all-time' || data.periodType == 'daily' || data.periodType == 'weekly' || data.periodType == 'monthly')
        && isShortString(data.scopeId, 180)
        && isShortString(data.periodKey, 80)
        && isShortString(data.attemptId, 220)
        && nonNegativeNumber(data.score, 10000000)
        && nonNegativeNumber(data.totalPoints, 10000000)
        && nonNegativeNumber(data.accuracy, 100)
        && nonNegativeNumber(data.timeTakenSeconds, 864000)
        && nonNegativeNumber(data.rankScore, 1000000000000)
        && nonNegativeNumber(data.aggregateAttempts, 100000)
        && data.hidden == false
        && attemptBelongsToRequester(data.attemptId);
    }

    function reportCreateShape(data) {
      return data.keys().hasOnly([
          'uid',
          'type',
          'targetId',
          'targetLabel',
          'targetUrl',
          'reportedBy',
          'reportedByName',
          'reason',
          'details',
          'status',
          'priority',
          'adminNote',
          'resolvedAt',
          'resolvedBy',
          'createdAt',
          'updatedAt'
        ])
        && data.uid == request.auth.uid
        && data.reportedBy == request.auth.uid
        && data.status == 'open'
        && (data.type in ['question', 'quiz', 'user', 'room', 'attempt', 'bug', 'other'])
        && (data.priority in ['low', 'medium', 'high'])
        && isShortString(data.targetId, 220)
        && isShortString(data.targetLabel, 260)
        && isShortString(data.targetUrl, 800)
        && isShortString(data.reportedByName, 120)
        && isShortString(data.reason, 260)
        && isShortString(data.details, 4000)
        && data.adminNote == ''
        && data.resolvedAt == null
        && data.resolvedBy == null;
    }

    function feedbackCreateShape(data) {
      return data.keys().hasOnly([
          'uid',
          'userId',
          'name',
          'email',
          'type',
          'message',
          'pageUrl',
          'status',
          'priority',
          'adminNote',
          'createdAt',
          'updatedAt'
        ])
        && data.uid == request.auth.uid
        && data.userId == request.auth.uid
        && data.status == 'new'
        && (data.type in ['bug', 'feature', 'general', 'ui', 'quiz-quality'])
        && (data.priority in ['low', 'medium', 'high'])
        && isShortString(data.name, 120)
        && isShortString(data.email, 180)
        && isShortString(data.message, 4000)
        && isShortString(data.pageUrl, 800)
        && data.adminNote == '';
    }

    function hostRoomUpdateAllowed() {
      return signedIn()
        && resource.data.hostId == request.auth.uid
        && request.resource.data.hostId == resource.data.hostId
        && (
          (
            resource.data.status == 'waiting'
            && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
              'status',
              'visibility',
              'settings',
              'locked',
              'playerCount',
              'currentQuestionIndex',
              'questionStartedAt',
              'questionEndsAt',
              'startedAt',
              'analytics',
              'antiAbuse',
              'rematchRoomId',
              'challengeId',
              'matchmakingStatus',
              'botFillUsed',
              'botFillAt',
              'updatedAt'
            ])
          )
          || (
            resource.data.status == 'in-progress'
            && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
              'status',
              'currentQuestionIndex',
              'questionStartedAt',
              'questionEndsAt',
              'completedAt',
              'analytics',
              'antiAbuse',
              'matchmakingStatus',
              'updatedAt'
            ])
          )
          || (
            resource.data.status == 'completed'
            && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
              'rematchRoomId',
              'updatedAt'
            ])
          )
        );
    }

    function roomJoinStatsUpdateAllowed(roomId) {
      return signedIn()
        && isRoomParticipantAfter(roomId)
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'playerCount',
          'analytics',
          'antiAbuse',
          'matchmakingStatus',
          'updatedAt'
        ])
        && request.resource.data.playerCount >= 0
        && request.resource.data.playerCount <= resource.data.maxPlayers;
    }

    function realRoomPlayerCreateAllowed(roomPlayerId) {
      return request.resource.data.userId == request.auth.uid
        && request.resource.data.isBot != true
        && roomPlayerId == roomPlayerDocId(request.resource.data.roomId, request.auth.uid)
        && roomAcceptsRealPlayer(request.resource.data.roomId);
    }

    function botRoomPlayerCreateAllowed(roomPlayerId) {
      return request.resource.data.isBot == true
        && request.resource.data.userId.matches('bot_.*')
        && roomPlayerId == roomPlayerDocId(request.resource.data.roomId, request.resource.data.userId)
        && isRoomHost(request.resource.data.roomId);
    }

    function ownRoomPlayerUpdateAllowed() {
      return signedIn()
        && resource.data.userId == request.auth.uid
        && resource.data.isBot != true
        && request.resource.data.userId == resource.data.userId
        && request.resource.data.roomId == resource.data.roomId
        && request.resource.data.isBot == resource.data.isBot
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'status',
          'currentAnswerStatus',
          'lastSeenAt'
        ]);
    }

    function realRoomAnswerCreateAllowed() {
      return request.resource.data.isBot != true
        && request.resource.data.userId == request.auth.uid
        && roomExists(request.resource.data.roomId)
        && isRoomParticipantAfter(request.resource.data.roomId);
    }

    function botRoomAnswerCreateAllowed() {
      return request.resource.data.isBot == true
        && request.resource.data.userId.matches('bot_.*')
        && roomExists(request.resource.data.roomId)
        && isRoomHost(request.resource.data.roomId);
    }

    function hostSkippedRoomAnswerCreateAllowed() {
      return request.resource.data.isBot != true
        && roomExists(request.resource.data.roomId)
        && isRoomHost(request.resource.data.roomId)
        && request.resource.data.isCorrect == false
        && request.resource.data.pointsEarned == 0
        && request.resource.data.selectedAnswer == ''
        && request.resource.data.selectedAnswers.size() == 0;
    }

    function roomAnswerShape(data) {
      return nonNegativeNumber(data.questionIndex, 10000)
        && nonNegativeNumber(data.pointsEarned, 100000)
        && nonNegativeNumber(data.pointsPossible, 100000)
        && nonNegativeNumber(data.timeTakenSeconds, 86400)
        && isShortString(data.questionId, 200)
        && isShortString(data.questionTextSnapshot, 2000)
        && boundedList(data.selectedAnswers, 30)
        && boundedList(data.correctAnswers, 30)
        && boundedList(data.optionsSnapshot, 30);
    }

    function creatorQuizCreateAllowed() {
      return hasCreatorAccess()
        && request.resource.data.ownerId == request.auth.uid
        && request.resource.data.createdBy == request.auth.uid
        && request.resource.data.ownerType == 'creator'
        && request.resource.data.status == 'draft'
        && request.resource.data.visibility == 'private'
        && request.resource.data.publishScope in ['class-only', 'private', 'global']
        && request.resource.data.reviewStatus == 'draft'
        && request.resource.data.isFeatured == false
        && request.resource.data.isDailyChallenge == false;
    }

    function creatorQuizUpdateAllowed() {
      return hasCreatorAccess()
        && resource.data.ownerId == request.auth.uid
        && resource.data.ownerType == 'creator'
        && request.resource.data.ownerId == resource.data.ownerId
        && request.resource.data.createdBy == resource.data.createdBy
        && request.resource.data.ownerType == resource.data.ownerType
        && request.resource.data.status in ['draft', 'archived']
        && request.resource.data.visibility == 'private'
        && request.resource.data.publishScope in ['class-only', 'private', 'global']
        && request.resource.data.reviewStatus == 'draft'
        && request.resource.data.isFeatured == false
        && request.resource.data.isDailyChallenge == false;
    }

    function creatorQuestionManageAllowed(data) {
      return hasCreatorAccess()
        && data.quizId is string
        && isQuizOwner(data.quizId)
        && get(quizPath(data.quizId)).data.ownerType == 'creator'
        && get(quizPath(data.quizId)).data.publishScope in ['class-only', 'private', 'global']
        && get(quizPath(data.quizId)).data.reviewStatus in ['draft', 'rejected'];
    }

    function creatorRequestCreateAllowed(requestId, data) {
      return signedIn()
        && requestId == request.auth.uid
        && data.keys().hasOnly([
          'userId',
          'displayName',
          'email',
          'photoURL',
          'reason',
          'interests',
          'experience',
          'intendedUse',
          'agreementAccepted',
          'status',
          'adminNote',
          'reviewedBy',
          'reviewedByName',
          'reviewedAt',
          'createdAt',
          'updatedAt'
        ])
        && data.userId == request.auth.uid
        && isShortString(data.displayName, 120)
        && isShortString(data.email, 180)
        && nullableShortString(data.photoURL, 600)
        && isShortString(data.reason, 2000)
        && isShortString(data.interests, 600)
        && isShortString(data.experience, 600)
        && isShortString(data.intendedUse, 80)
        && data.agreementAccepted == true
        && data.status == 'pending'
        && data.adminNote == ''
        && data.reviewedBy == ''
        && data.reviewedByName == ''
        && data.reviewedAt == null
        && nullableTimestamp(data.createdAt)
        && nullableTimestamp(data.updatedAt);
    }

    function roomReadAllowed(roomId) {
      return signedIn()
        && (
          isAdmin()
          || resource.data.allowedMemberOnly != true
          || resource.data.hostId == request.auth.uid
          || isActiveClassMember(resource.data.classId)
        );
    }

    function roomCreateAllowed(data) {
      return signedIn()
        && data.hostId == request.auth.uid
        && data.status == 'waiting'
        && isPublishedPublicQuiz(data.quizId)
        && nonNegativeNumber(data.maxPlayers, 50)
        && data.playerCount == 1
        && (
          data.source != 'class-room'
          || (
            data.visibility == 'private'
            && data.allowedMemberOnly == true
            && isShortString(data.classId, 180)
            && canManageClass(data.classId)
          )
        );
    }

    function classCreateShape(data) {
      return data.keys().hasOnly([
          'name',
          'slug',
          'description',
          'subject',
          'gradeLevel',
          'coverAccent',
          'ownerId',
          'ownerName',
          'organizationName',
          'status',
          'visibility',
          'inviteCode',
          'memberCount',
          'assignmentCount',
          'roomCount',
          'averageAccuracy',
          'createdAt',
          'updatedAt',
          'archivedAt'
        ])
        && data.ownerId == request.auth.uid
        && data.status == 'active'
        && data.visibility == 'invite-only'
        && isShortString(data.name, 140)
        && isShortString(data.slug, 180)
        && isShortString(data.description, 1200)
        && isShortString(data.subject, 120)
        && isShortString(data.gradeLevel, 80)
        && isShortString(data.coverAccent, 220)
        && isShortString(data.ownerName, 140)
        && isShortString(data.organizationName, 180)
        && isShortString(data.inviteCode, 24)
        && nonNegativeNumber(data.memberCount, 100000)
        && nonNegativeNumber(data.assignmentCount, 100000)
        && nonNegativeNumber(data.roomCount, 100000)
        && nonNegativeNumber(data.averageAccuracy, 100)
        && nullableTimestamp(data.archivedAt);
    }

    function classOwnerUpdateAllowed(classId) {
      return canManageClass(classId)
        && request.resource.data.ownerId == resource.data.ownerId
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'name',
          'slug',
          'description',
          'subject',
          'gradeLevel',
          'coverAccent',
          'organizationName',
          'status',
          'visibility',
          'inviteCode',
          'memberCount',
          'assignmentCount',
          'roomCount',
          'averageAccuracy',
          'updatedAt',
          'archivedAt'
        ]);
    }

    function classJoinStatsUpdateAllowed(classId) {
      return signedIn()
        && isActiveClass(classId)
        && existsAfter(classMemberPath(classId, request.auth.uid))
        && getAfter(classMemberPath(classId, request.auth.uid)).data.userId == request.auth.uid
        && getAfter(classMemberPath(classId, request.auth.uid)).data.role == 'student'
        && request.resource.data.ownerId == resource.data.ownerId
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'memberCount',
          'updatedAt'
        ])
        && request.resource.data.memberCount >= resource.data.memberCount
        && request.resource.data.memberCount <= resource.data.memberCount + 1;
    }

    function classMemberShape(memberId, data) {
      return data.keys().hasOnly([
          'classId',
          'userId',
          'displayName',
          'email',
          'photoURL',
          'inviteCode',
          'role',
          'status',
          'joinedAt',
          'lastActiveAt',
          'stats'
        ])
        && data.classId is string
        && data.userId is string
        && memberId == classMemberDocId(data.classId, data.userId)
        && isShortString(data.displayName, 140)
        && nullableShortString(data.email, 180)
        && nullableShortString(data.photoURL, 600)
        && nullableShortString(data.inviteCode, 24)
        && data.role in ['teacher', 'assistant', 'student']
        && data.status in ['active', 'removed', 'pending']
        && (data.stats == null || data.stats is map);
    }

    function teacherMembershipCreateAllowed(memberId) {
      return classMemberShape(memberId, request.resource.data)
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.role == 'teacher'
        && request.resource.data.status == 'active'
        && canManageClassAfter(request.resource.data.classId);
    }

    function studentMembershipCreateAllowed(memberId) {
      return classMemberShape(memberId, request.resource.data)
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.role == 'student'
        && request.resource.data.status == 'active'
        && isActiveClass(request.resource.data.classId)
        && request.resource.data.inviteCode is string
        && exists(classInvitePath(request.resource.data.inviteCode))
        && get(classInvitePath(request.resource.data.inviteCode)).data.classId == request.resource.data.classId
        && get(classInvitePath(request.resource.data.inviteCode)).data.status == 'active';
    }

    function ownMemberHeartbeatAllowed() {
      return signedIn()
        && resource.data.userId == request.auth.uid
        && request.resource.data.userId == resource.data.userId
        && request.resource.data.role == resource.data.role
        && request.resource.data.classId == resource.data.classId
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'lastActiveAt'
        ]);
    }

    function classInviteShape(data) {
      return data.keys().hasOnly([
          'classId',
          'inviteCode',
          'createdBy',
          'status',
          'expiresAt',
          'maxUses',
          'usedCount',
          'createdAt',
          'updatedAt'
        ])
        && isShortString(data.classId, 180)
        && isShortString(data.inviteCode, 24)
        && data.createdBy == request.auth.uid
        && data.status in ['active', 'disabled', 'expired']
        && nullableTimestamp(data.expiresAt)
        && nonNegativeNumber(data.maxUses, 100000)
        && nonNegativeNumber(data.usedCount, 100000);
    }

    function inviteUseCountUpdateAllowed() {
      return signedIn()
        && resource.data.status == 'active'
        && isActiveClass(resource.data.classId)
        && existsAfter(classMemberPath(resource.data.classId, request.auth.uid))
        && getAfter(classMemberPath(resource.data.classId, request.auth.uid)).data.role == 'student'
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'usedCount',
          'updatedAt'
        ])
        && request.resource.data.usedCount >= resource.data.usedCount
        && request.resource.data.usedCount <= resource.data.usedCount + 1;
    }

    function assignmentPath(assignmentId) {
      return /databases/$(database)/documents/assignments/$(assignmentId);
    }

    function assignmentExists(assignmentId) {
      return assignmentId is string && exists(assignmentPath(assignmentId));
    }

    function assignmentSubmissionDocId(assignmentId, uid) {
      return assignmentId + '_' + uid;
    }

    function assignmentSubmissionShape(submissionId, data) {
      return data.keys().hasOnly([
          'assignmentId',
          'classId',
          'quizId',
          'userId',
          'userDisplayName',
          'attemptId',
          'status',
          'score',
          'totalPoints',
          'accuracy',
          'timeTakenSeconds',
          'submittedAt',
          'dueAt',
          'createdAt',
          'updatedAt'
        ])
        && data.userId == request.auth.uid
        && submissionId == assignmentSubmissionDocId(data.assignmentId, request.auth.uid)
        && assignmentExists(data.assignmentId)
        && get(assignmentPath(data.assignmentId)).data.classId == data.classId
        && isActiveClassMember(data.classId)
        && data.status in ['submitted', 'late', 'in-progress', 'missing']
        && nonNegativeNumber(data.score, 1000000)
        && nonNegativeNumber(data.totalPoints, 1000000)
        && nonNegativeNumber(data.accuracy, 100)
        && nonNegativeNumber(data.timeTakenSeconds, 86400)
        && nullableTimestamp(data.dueAt);
    }

    function classLeaderboardRowShape(rowId, data) {
      return data.keys().hasOnly([
          'classId',
          'userId',
          'displayName',
          'photoURL',
          'completedAssignments',
          'totalScore',
          'averageAccuracy',
          'lastSubmittedAt',
          'createdAt',
          'updatedAt'
        ])
        && data.userId == request.auth.uid
        && rowId == classMemberDocId(data.classId, request.auth.uid)
        && isActiveClassMember(data.classId)
        && isShortString(data.displayName, 140)
        && nullableShortString(data.photoURL, 600)
        && nonNegativeNumber(data.completedAssignments, 100000)
        && nonNegativeNumber(data.totalScore, 10000000)
        && nonNegativeNumber(data.averageAccuracy, 100)
        && nullableTimestamp(data.lastSubmittedAt);
    }

    match /users/{uid} {
      allow create: if isSelf(uid)
        && userProfileCreateShape(request.resource.data, uid);
      allow get: if isSelf(uid) || isAdmin();
      allow list: if isAdmin();
      allow update: if selfProfileUpdateAllowed(uid) || isAdmin();
      allow delete: if isAdmin();
    }

    match /creatorRequests/{requestId} {
      allow get: if isAdmin() || isSelf(requestId);
      allow list: if isAdmin();
      allow create: if creatorRequestCreateAllowed(requestId, request.resource.data);
      allow update, delete: if isAdmin();
    }

    match /categories/{categoryId} {
      allow get, list: if resource.data.status == 'active' || isAdmin();
      allow create, update, delete: if isAdmin();
    }

    match /quizzes/{quizId} {
      allow get, list: if publicQuizReadAllowed(resource.data)
        || isAdmin()
        || (signedIn() && resource.data.ownerId == request.auth.uid);
      allow create: if isAdmin() || creatorQuizCreateAllowed();
      allow update: if isAdmin() || creatorQuizUpdateAllowed();
      allow delete: if isAdmin()
        || (
          hasCreatorAccess()
          && resource.data.ownerId == request.auth.uid
          && resource.data.ownerType == 'creator'
          && resource.data.status in ['draft', 'archived']
        );
    }

    match /questions/{questionId} {
      allow get, list: if isAdmin()
        || creatorQuestionManageAllowed(resource.data)
        || (
          signedIn()
          && resource.data.status == 'active'
          && isPublishedPublicQuiz(resource.data.quizId)
        );
      allow create: if isAdmin() || creatorQuestionManageAllowed(request.resource.data);
      allow update: if isAdmin()
        || (
          creatorQuestionManageAllowed(resource.data)
          && request.resource.data.quizId == resource.data.quizId
        );
      allow delete: if isAdmin() || creatorQuestionManageAllowed(resource.data);
    }

    match /attempts/{attemptId} {
      allow get, list: if signedIn()
        && (resource.data.userId == request.auth.uid || isAdmin());
      allow create, update: if isAdmin();
      allow delete: if isAdmin();
    }

    match /attemptSessions/{sessionId} {
      allow get, list: if signedIn()
        && (resource.data.userId == request.auth.uid || isAdmin());
      allow create, update, delete: if isAdmin();
    }

    match /leaderboards/{leaderboardId} {
      allow read: if isAdmin()
        || (
          resource.data.hidden != true
          && resource.data.trusted == true
          && resource.data.botEntry != true
        );
      allow create, update: if isAdmin();
      allow delete: if isAdmin();
    }

    match /rooms/{roomId} {
      // Signed-in room-code lookup is intentionally allowed for Phase 9 invite links.
      // Private room discoverability must move to a trusted lookup endpoint later.
      allow get, list: if roomReadAllowed(roomId);
      allow create: if roomCreateAllowed(request.resource.data);
      allow update: if isAdmin()
        || hostRoomUpdateAllowed()
        || roomJoinStatsUpdateAllowed(roomId);
      allow delete: if isAdmin();
    }

    match /roomPlayers/{roomPlayerId} {
      allow read: if signedIn() && canReadRoomScopedData(resource.data.roomId);
      allow create: if signedIn()
        && (
          realRoomPlayerCreateAllowed(roomPlayerId)
          || botRoomPlayerCreateAllowed(roomPlayerId)
          || isAdmin()
        )
        && nonNegativeNumber(request.resource.data.score, 1000000)
        && nonNegativeNumber(request.resource.data.correctCount, 10000)
        && nonNegativeNumber(request.resource.data.wrongCount, 10000)
        && nonNegativeNumber(request.resource.data.skippedCount, 10000);
      allow update: if isAdmin()
        || isRoomHost(resource.data.roomId)
        || ownRoomPlayerUpdateAllowed();
      allow delete: if isAdmin();
    }

    match /roomAnswers/{roomAnswerId} {
      allow read: if signedIn()
        && (
          isAdmin()
          || isRoomHost(resource.data.roomId)
          || isRoomParticipant(resource.data.roomId)
        );
      allow create: if isAdmin();
      allow update: if false;
      allow delete: if isAdmin();
    }

    match /roomResults/{roomResultId} {
      allow read: if signedIn()
        && (
          isAdmin()
          || isRoomHost(resource.data.roomId)
          || isRoomParticipant(resource.data.roomId)
          || resource.data.userId == request.auth.uid
        );
      allow create, update: if isAdmin();
      allow delete: if isAdmin();
    }

    match /flashQuizzes/{flashQuizId} {
      allow get: if canReadFlashQuiz(flashQuizId);
      allow list: if signedIn()
        && (
          isAdmin()
          || resource.data.hostId == request.auth.uid
          || isFlashParticipant(flashQuizId)
        );
      allow create, update, delete: if isAdmin();
    }

    match /flashQuestions/{questionId} {
      allow read: if signedIn()
        && (
          isAdmin()
          || isFlashHost(resource.data.flashQuizId)
        );
      allow create, update, delete: if isAdmin();
    }

    match /flashPlayers/{playerId} {
      allow read: if signedIn()
        && canReadFlashScopedData(resource.data.flashQuizId);
      allow create, update, delete: if isAdmin();
    }

    match /flashAnswers/{answerId} {
      allow read: if signedIn()
        && (
          isAdmin()
          || isFlashHost(resource.data.flashQuizId)
          || resource.data.userId == request.auth.uid
        );
      allow create, update, delete: if isAdmin();
    }

    match /flashResults/{resultId} {
      allow read: if signedIn()
        && (
          isAdmin()
          || isFlashHost(resource.data.flashQuizId)
          || isFlashParticipant(resource.data.flashQuizId)
          || resource.data.userId == request.auth.uid
        );
      allow create, update, delete: if isAdmin();
    }

    match /flashReports/{reportId} {
      allow read, update, delete: if isAdmin();
      allow create: if isAdmin();
    }

    match /matchmakingQueue/{queueId} {
      allow get: if isSelf(queueId) || isAdmin();
      allow list: if isAdmin();
      allow create: if isSelf(queueId)
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.status in ['searching', 'matched', 'cancelled', 'expired']
        && nonNegativeNumber(request.resource.data.questionTimerSeconds, 180);
      allow update: if isAdmin()
        || (
          isSelf(queueId)
          && resource.data.userId == request.auth.uid
          && request.resource.data.userId == resource.data.userId
          && request.resource.data.status in ['searching', 'matched', 'cancelled', 'expired']
          && nonNegativeNumber(request.resource.data.questionTimerSeconds, 180)
        );
      allow delete: if isAdmin();
    }

    match /challenges/{challengeId} {
      allow get: if signedIn()
        && (
          resource.data.status in ['active', 'joined']
          || resource.data.createdBy == request.auth.uid
          || isAdmin()
        );
      allow list: if isAdmin();
      allow create: if signedIn()
        && request.resource.data.createdBy == request.auth.uid
        && request.resource.data.status == 'active'
        && isShortString(request.resource.data.quizId, 160)
        && isShortString(request.resource.data.roomCode, 20);
      allow update: if isAdmin()
        || (
          signedIn()
          && resource.data.createdBy == request.auth.uid
          && request.resource.data.createdBy == resource.data.createdBy
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
            'status',
            'updatedAt'
          ])
          && request.resource.data.status in ['active', 'expired', 'cancelled']
        )
        || (
          signedIn()
          && resource.data.status == 'active'
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
            'status',
            'acceptedBy',
            'updatedAt'
          ])
          && request.resource.data.acceptedBy == request.auth.uid
          && request.resource.data.status == 'joined'
        );
      allow delete: if isAdmin();
    }

    match /classes/{classId} {
      allow get, list: if isAdmin() || isClassOwner(classId) || isActiveClassMember(classId);
      allow create: if hasCreatorAccess()
        && classCreateShape(request.resource.data);
      allow update: if classOwnerUpdateAllowed(classId) || classJoinStatsUpdateAllowed(classId);
      allow delete: if isAdmin();
    }

    match /classMembers/{memberId} {
      allow get, list: if isAdmin()
        || resource.data.userId == request.auth.uid
        || isClassOwner(resource.data.classId)
        || isClassTeacher(resource.data.classId);
      allow create: if signedIn()
        && (
          teacherMembershipCreateAllowed(memberId)
          || studentMembershipCreateAllowed(memberId)
          || isAdmin()
        );
      allow update: if isAdmin()
        || canManageClass(resource.data.classId)
        || ownMemberHeartbeatAllowed();
      allow delete: if isAdmin() || canManageClass(resource.data.classId);
    }

    match /classInvites/{inviteId} {
      allow get: if signedIn()
        && (
          resource.data.status == 'active'
          || canManageClass(resource.data.classId)
          || isAdmin()
        );
      allow list: if isAdmin();
      allow create: if isAdmin()
        || (
          classInviteShape(request.resource.data)
          && canManageClassAfter(request.resource.data.classId)
        );
      allow update: if isAdmin()
        || canManageClass(resource.data.classId)
        || inviteUseCountUpdateAllowed();
      allow delete: if isAdmin() || canManageClass(resource.data.classId);
    }

    match /assignments/{assignmentId} {
      allow get, list: if isAdmin()
        || canManageClass(resource.data.classId)
        || (
          isActiveClassMember(resource.data.classId)
          && resource.data.status in ['published', 'closed']
        );
      allow create: if signedIn()
        && canManageClass(request.resource.data.classId)
        && request.resource.data.createdBy == request.auth.uid
        && request.resource.data.status in ['draft', 'published', 'closed'];
      allow update: if isAdmin() || canManageClass(resource.data.classId);
      allow delete: if isAdmin() || canManageClass(resource.data.classId);
    }

    match /assignmentSubmissions/{submissionId} {
      allow get, list: if isAdmin()
        || resource.data.userId == request.auth.uid
        || canManageClass(resource.data.classId);
      allow create, update: if isAdmin() || canManageClass(request.resource.data.classId);
      allow delete: if isAdmin() || canManageClass(resource.data.classId);
    }

    match /classLeaderboardRows/{rowId} {
      allow get, list: if isAdmin()
        || canManageClass(resource.data.classId)
        || isActiveClassMember(resource.data.classId);
      allow create, update: if isAdmin() || canManageClass(request.resource.data.classId);
      allow delete: if isAdmin() || canManageClass(resource.data.classId);
    }

    match /reports/{reportId} {
      allow create: if signedIn() && reportCreateShape(request.resource.data);
      allow read, update, delete: if isAdmin();
    }

    match /feedback/{feedbackId} {
      allow create: if signedIn() && feedbackCreateShape(request.resource.data);
      allow read, update, delete: if isAdmin();
    }

    match /siteSettings/{settingId} {
      allow read: if resource.data.public == true || isAdmin();
      allow write: if isAdmin();
    }

    match /dailyChallenges/{challengeId} {
      allow read: if resource.data.status in ['active', 'scheduled'] || isAdmin();
      allow write: if isAdmin();
    }

    match /plans/{planId} {
      allow read: if resource.data.isActive == true || isAdmin();
      allow write: if isAdmin();
    }

    match /entitlements/{entitlementId} {
      allow read: if isAdmin()
        || (signedIn() && resource.data.userId == request.auth.uid);
      allow create, update, delete: if isAdmin();
    }

    match /billingOrders/{orderId} {
      allow read: if isAdmin()
        || (signedIn() && resource.data.userId == request.auth.uid);
      allow write: if isAdmin();
    }

    match /payments/{paymentId} {
      allow read: if isAdmin()
        || (signedIn() && resource.data.userId == request.auth.uid);
      allow write: if isAdmin();
    }

    match /webhookEvents/{eventId} {
      allow read, write: if isAdmin();
    }

    match /refunds/{refundId} {
      allow read: if isAdmin()
        || (signedIn() && resource.data.userId == request.auth.uid);
      allow write: if isAdmin();
    }

    match /usageCounters/{counterId} {
      allow read: if isAdmin()
        || (signedIn() && resource.data.userId == request.auth.uid);
      allow write: if isAdmin();
    }

    match /billingAuditLogs/{logId} {
      allow read, write: if isAdmin();
    }

    match /adminLogs/{logId} {
      allow read, write: if isAdmin();
    }
  }
}
