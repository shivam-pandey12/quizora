NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
NEXT_PUBLIC_APP_URL=

# Razorpay / billing
NEXT_PUBLIC_RAZORPAY_KEY_ID=
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=
BILLING_CURRENCY=INR
BILLING_TEST_MODE=true
BILLING_SUPPORT_EMAIL=
SUPPORT_EMAIL=

# Optional local Firebase Admin SDK credentials for Next.js API routes.
# Production hosts can use application default credentials instead.
# Use one credential style only; never expose these as NEXT_PUBLIC_* values.
FIREBASE_SERVICE_ACCOUNT_JSON=
FIREBASE_SERVICE_ACCOUNT_BASE64=
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=

# Trusted scoring / Phase 14
# Use a random 32+ character secret. Never expose this publicly.
ATTEMPT_SESSION_SECRET=
TRUSTED_SCORING_ENABLED=true
NEXT_PUBLIC_TRUSTED_SCORING_ENABLED=true
COMPETITIVE_MODE_ENABLED=true

# Optional launch operations
